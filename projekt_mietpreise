#Import Pandas
import pandas as pd

#Import CSV File
url = "https://raw.githubusercontent.com/selva86/datasets/master/BostonHousing.csv"
df = pd.read_csv(url)

#Show the first 5 rows of the dataset
print(df.head())

#Analyze the dataset: info = data types, missing values, etc. describe = statistical summary of the dataset
print(df.info())
print(df.describe())

#Visualize the relationship between the number of rooms (rm) and the price (medv)

import matplotlib.pyplot as plt
